VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_GOOGLE_SHEET_URL=your_google_apps_script_url

# Gemini API key for Meka Assistant (frontend chat widget).
# Get one at https://aistudio.google.com/apikey
# IMPORTANT: This key ships to the browser. Before going to production:
#   1. Restrict the key in Google Cloud Console to your production domain (HTTP referrers).
#   2. Enable only the Generative Language API.
#   3. Consider moving calls through a small backend proxy if you expect abuse.
VITE_GEMINI_API_KEY=your_gemini_api_key

# Sanity CMS — content for the Hero section (and future sections) is edited in Sanity Studio.
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production
